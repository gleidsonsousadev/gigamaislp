<style>
  .faq-item {
    background: rgba(0, 0, 80, 0.06);
    border: 1px solid #b0c2d2;
    border-radius: 24px;
    overflow: hidden;
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }

  .faq-summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 24px;
    cursor: pointer;
    list-style: none;
    font-size: 18px;
    font-weight: 500;
    color: #010180;
    line-height: 24px;
    gap: 16px;
  }

  .faq-summary::-webkit-details-marker {
    display: none;
  }

  .faq-icon {
    flex-shrink: 0;
    transition: transform 0.25s ease;
  }

  details[open] .faq-icon {
    transform: rotate(180deg);
  }

  .faq-body {
    border-top: 1px solid #b0c2d2;
    padding: 13px 24px 24px;
  }

  .faq-body p {
    font-size: 16px;
    font-weight: 400;
    color: #5a5a5a;
    line-height: 24px;
    margin: 0;
  }
</style>

<script>
  const items = document.querySelectorAll<HTMLDetailsElement>('.faq-item');
  items.forEach(item => {
    item.addEventListener('toggle', () => {
      if (item.open) {
        items.forEach(other => { if (other !== item) other.open = false; });
      }
    });
  });
</script>
