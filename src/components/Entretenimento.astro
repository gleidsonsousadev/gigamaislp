---
---

<div style="width: 100%; height: 2px; background: linear-gradient(to right, #000050, #00EF52 50%, #000050);"></div>
<section class="entret-section" style="position: relative; width: 100%; background: #000026; height: 713px; overflow: hidden;">

  <!-- Imagem desktop -->
  <img
    src="/images/bg-entretenimento.jpg"
    alt=""
    class="entret-img-desktop"
    style="
      position: absolute;
      left: 0;
      top: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center top;
      mix-blend-mode: lighten;
      pointer-events: none;
    "
  />

  <!-- Imagem mobile: 390x417px, centralizada -->
  <img
    src="/images/bg-entretenimento-mobile.jpg"
    alt=""
    class="entret-img-mobile"
    style="display: none; position: absolute; left: 0; top: 0; width: 100%; height: 417px; object-fit: cover; object-position: center top; pointer-events: none;"
  />

  <!-- Fade mobile: linear-gradient de cima para baixo -->
  <div class="entret-fade-mobile" style="display: none; position: absolute; left: 0; top: 232px; width: 100%; height: 369px; background: linear-gradient(to bottom, rgba(0,0,38,0) 0%, #000026 48%); pointer-events: none; z-index: 1;"></div>

  <!-- Card glassmorphism centralizado -->
  <div class="entret-card-wrapper" style="position: absolute; inset: 0; display: flex; justify-content: center; align-items: flex-end; padding-bottom: calc(713px - 394px - 238px);">
    <div class="entret-card" style="
      width: 733px;
      display: flex;
      flex-direction: column;
      gap: 44px;
      padding: 36px;
      border-radius: 1.5rem;
      border: 0.7px solid rgba(255, 255, 255, 0.11);
      background: linear-gradient(to bottom, rgba(255,255,255,0.16), rgba(255,255,255,0.02));
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      box-sizing: border-box;
    ">

      <p class="entret-title" style="font-size: 40px; font-weight: 500; line-height: 48px; margin: 0; color: #00EF52;">
        Sua Internet <span style="color: #fff;">Giga+</span> é o passaporte para o melhor do <span style="color: #fff;">entretenimento.</span>
      </p>

      <a href="#contratar" class="entret-btn" style="
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: #00EF52;
        color: #010180;
        font-size: 18px;
        font-weight: 600;
        padding: 12px 24px;
        border-radius: 999px;
        text-decoration: none;
        white-space: nowrap;
        width: fit-content;
      ">
        Assine agora
      </a>

    </div>
  </div>


</section>

<style>
  @media (max-width: 768px) {
    /* Seção: altura fixa 516px conforme Figma */
    .entret-section {
      height: 516px !important;
    }

    /* Imagem desktop: oculta */
    .entret-img-desktop {
      display: none !important;
    }

    /* Imagem mobile: visível */
    .entret-img-mobile {
      display: block !important;
    }

    /* Fade mobile: visível */
    .entret-fade-mobile {
      display: block !important;
    }

    /* Card wrapper: posicionamento absoluto, card em top=216px centralizado */
    .entret-card-wrapper {
      padding-bottom: 0 !important;
      align-items: flex-start !important;
      justify-content: center !important;
      padding-top: 216px !important;
      z-index: 2 !important;
      position: absolute !important;
      inset: 0 !important;
    }

    /* Card: width=342px, padding=24px, gap=44px, border-radius=24px */
    .entret-card {
      width: 342px !important;
      padding: 24px !important;
      gap: 44px !important;
      border-radius: 24px !important;
    }

    /* Título: 28px, line-height 32px, centralizado */
    .entret-title {
      font-size: 28px !important;
      line-height: 32px !important;
      text-align: center !important;
    }

    /* Botão: centralizado (não full width), border-radius 24px */
    .entret-btn {
      align-self: center !important;
      border-radius: 24px !important;
      width: auto !important;
    }
  }
</style>
