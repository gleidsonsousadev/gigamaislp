---
---

<div style="width: 100%; height: 2px; background: linear-gradient(to right, #000050, #00EF52 50%, #000050);"></div>
<section style="position: relative; width: 100%; background: #000026; height: 713px; overflow: hidden;">

  <!-- Imagem de fundo full-width com mix-blend-mode lighten -->
  <img
    src="/images/bg-entretenimento.jpg"
    alt=""
    style="
      position: absolute;
      left: 0;
      top: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center top;
      mix-blend-mode: lighten;
      pointer-events: none;
    "
  />

  <!-- Card glassmorphism centralizado -->
  <div style="position: absolute; inset: 0; display: flex; justify-content: center; align-items: flex-end; padding-bottom: calc(713px - 394px - 238px);">
    <div style="
      width: 733px;
      display: flex;
      flex-direction: column;
      gap: 44px;
      padding: 36px;
      border-radius: 1.5rem;
      border: 0.7px solid rgba(255, 255, 255, 0.11);
      background: linear-gradient(to bottom, rgba(255,255,255,0.16), rgba(255,255,255,0.02));
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      box-sizing: border-box;
    ">

      <p style="font-size: 40px; font-weight: 500; line-height: 48px; margin: 0; color: #00EF52;">
        Sua Internet <span style="color: #fff;">Giga+</span> é o passaporte para o melhor do <span style="color: #fff;">entretenimento.</span>
      </p>

      <a href="#contratar" style="
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: #00EF52;
        color: #010180;
        font-size: 18px;
        font-weight: 600;
        padding: 12px 24px;
        border-radius: 999px;
        text-decoration: none;
        white-space: nowrap;
        width: fit-content;
      ">
        Assine agora
      </a>

    </div>
  </div>

</section>
