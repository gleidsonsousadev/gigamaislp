---

<section class="cta-section" style="width: 100%; background: #00EF52; height: 425px; display: flex; align-items: center; justify-content: center;">

  <div style="display: flex; flex-direction: column; gap: 33px; align-items: center; text-align: center; width: 100%; max-width: 1392px; padding: 0 32px; box-sizing: border-box;">

    <!-- Título + subtítulo -->
    <div style="display: flex; flex-direction: column; gap: 11px; align-items: center;">
      <p style="font-size: 40px; font-weight: 500; line-height: 48px; margin: 0; color: #010180;">
        Chega de sofrer com <span style="color: #0939CF;">Internet lenta</span>
      </p>
      <p style="font-size: 16px; font-weight: 400; line-height: 24px; margin: 0; color: #010180;">
        Nossos consultores estão prontos para te ajudar a escolher o melhor plano agora mesmo.
      </p>
    </div>

    <!-- Botões -->
    <div class="cta-btns" style="display: flex; gap: 16px; align-items: center;">

      <!-- Botão Telefone (outline) -->
      <a href="tel:08007302200" class="cta-btn-tel" style="
        display: inline-flex;
        gap: 8px;
        align-items: center;
        justify-content: center;
        padding: 12px 24px;
        border-radius: 999px;
        border: 2px solid #010180;
        background: transparent;
        color: #010180;
        font-size: 18px;
        font-weight: 600;
        text-decoration: none;
        white-space: nowrap;
      ">
        <img src="/images/icon-telefone-dark.svg" alt="" width="24" height="24" style="display: block; flex-shrink: 0;" />
        0800 730 2200
      </a>

      <!-- Botão WhatsApp (filled) -->
      <a href="https://wa.me/5511936192300" target="_blank" rel="noopener" class="cta-btn-wa" style="
        display: inline-flex;
        gap: 8px;
        align-items: center;
        justify-content: center;
        padding: 12px 24px;
        border-radius: 999px;
        background: #010180;
        color: #00EF52;
        font-size: 18px;
        font-weight: 600;
        text-decoration: none;
        white-space: nowrap;
      ">
        <img src="/images/icon-whatsapp.svg" alt="" width="24" height="24" style="display: block; flex-shrink: 0;" />
        Contratar pelo WhatsApp
      </a>

    </div>

  </div>

</section>

<style>
  @media (max-width: 768px) {
    /* Seção: altura fixa 365px, centralizada */
    .cta-section {
      height: 365px !important;
      padding: 0 !important;
      align-items: center !important;
      justify-content: center !important;
    }

    /* Container: width 342px, gap 33px */
    .cta-section > div {
      width: 342px !important;
      max-width: 342px !important;
      padding: 0 !important;
      gap: 33px !important;
    }

    /* Título: 28px, line-height 32px */
    .cta-section p[style*="40px"] {
      font-size: 28px !important;
      line-height: 32px !important;
    }

    /* Botões: coluna, gap 16px, full width */
    .cta-btns {
      flex-direction: column !important;
      gap: 16px !important;
      width: 100% !important;
      align-items: stretch !important;
    }

    /* Botão telefone: outline, full width */
    .cta-btn-tel {
      width: 100% !important;
      justify-content: center !important;
      font-size: 18px !important;
      border-radius: 999px !important;
      box-sizing: border-box !important;
    }

    /* Botão WhatsApp: filled, full width */
    .cta-btn-wa {
      width: 100% !important;
      justify-content: center !important;
      font-size: 18px !important;
      border-radius: 999px !important;
      box-sizing: border-box !important;
    }
  }
</style>
