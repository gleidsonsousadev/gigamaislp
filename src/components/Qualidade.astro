<section class="qualidade-section" style="width: 100%; background: #fff; padding: 80px 32px;">

  <div style="max-width: 1440px; margin: 0 auto; display: flex; flex-direction: column; gap: 64px; align-items: center;">

    <!-- Título -->
    <h2 style="font-size: 40px; font-weight: 400; color: #010180; text-align: center; margin: 0; line-height: normal;">
      Nossos Números
    </h2>

    <!-- Números / estatísticas -->
    <div class="qualidade-stats" style="display: flex; gap: 26px; align-items: center; justify-content: center; text-align: center; color: #010180;">

      <div style="display: flex; flex-direction: column; gap: 5.6px; align-items: center;">
        <span style="font-size: 54px; font-weight: 500; color: #010180; line-height: normal;">+280</span>
        <span style="font-size: 24px; font-weight: 400; color: #010180; line-height: 41px;">Cidades</span>
      </div>

      <div style="display: flex; flex-direction: column; gap: 5.6px; align-items: center;">
        <span style="font-size: 54px; font-weight: 500; color: #010180; line-height: normal;">149mil</span>
        <span style="font-size: 24px; font-weight: 400; color: #010180; line-height: 41px;">Km de Rede de Fibra Óptica</span>
      </div>

      <div style="display: flex; flex-direction: column; gap: 5.6px; align-items: center;">
        <span style="font-size: 54px; font-weight: 500; color: #010180; line-height: normal;">1.5M</span>
        <span style="font-size: 24px; font-weight: 400; color: #010180; line-height: 41px;">Clientes</span>
      </div>

    </div>

  </div>

</section>

<style>
  .badge-premio {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px;
    background: rgba(1, 1, 128, 0.05);
    border-radius: 11px;
  }

  @media (max-width: 768px) {
    /* Seção: padding ajustado para mobile */
    .qualidade-section {
      padding: 61px 0 80px !important;
    }

    /* Título: 28px, centralizado com padding lateral */
    .qualidade-section h2 {
      font-size: 28px !important;
      padding: 0 24px !important;
    }

    /* Container superior: gap menor */
    .qualidade-section > div > div:first-child {
      gap: 24px !important;
    }

    /* Badges: slider horizontal com scroll, sem padding lateral (scroll vai até a borda) */
    .qualidade-badges {
      display: flex !important;
      flex-wrap: nowrap !important;
      gap: 8px !important;
      overflow-x: auto !important;
      overflow-y: hidden !important;
      justify-content: flex-start !important;
      padding: 5px 24px !important;
      width: 100% !important;
      box-sizing: border-box !important;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }

    .qualidade-badges::-webkit-scrollbar {
      display: none;
    }

    /* Cada badge: tamanho fixo, sem quebra de linha, shrink-0 */
    .badge-premio {
      flex-shrink: 0 !important;
      width: auto !important;
      height: 61.8px !important;
      border-radius: 10.6px !important;
      padding: 11.6px !important;
      gap: 8px !important;
      align-items: center !important;
    }

    .badge-premio span {
      font-size: 19px !important;
    }

    /* Stats: coluna, centralizado, gap 26px, fontes originais mantidas */
    .qualidade-stats {
      flex-direction: column !important;
      gap: 26px !important;
      padding: 0 24px !important;
    }
  }
</style>
