<section id="planos" class="planos-section" style="width: 100%; background: linear-gradient(123.24deg, #F3FFF7 5.05%, #C5D1DF 100.3%); padding: 80px 32px;">

  <div class="planos-inner" style="max-width: 1440px; margin: 0 auto; display: flex; flex-direction: column; gap: 32px;">

    <!-- Header da seção: título + seletor de cidade -->
    <div class="planos-header" style="display: flex; align-items: center; justify-content: space-between; width: 100%;">

      <!-- Título -->
      <div style="display: flex; flex-direction: column; gap: 11px; max-width: 617px;">
        <h2 style="font-size: 40px; line-height: 48px; font-weight: 500; margin: 0;">
          <span style="color: #010180;">Escolha sua</span>
          <span style="color: #0939CF;"> Experiência</span>
        </h2>
        <p style="font-size: 18px; line-height: 24px; font-weight: 400; color: #010180; margin: 0;">
          Planos pensados para quem não aceita menos que o topo da performance digital.
        </p>
      </div>

      <!-- Seletor: cidade + radio buttons -->
      <div class="planos-seletor" style="display: flex; gap: 5.6px; align-items: center; justify-content: center; padding: 16px; background: rgba(1,1,128,0.1); border-radius: 24px; flex-shrink: 0;">

        <!-- Cidade + Trocar Cidade -->
        <div style="display: flex; gap: 16px; align-items: center; padding: 6px 6px 6px 17px; border-radius: 32px;">
          <div style="display: flex; flex-direction: column;">
            <span style="font-size: 12px; font-weight: 600; color: #0939CF; letter-spacing: 1.56px; line-height: normal;">CIDADE</span>
            <span id="cidade-label" style="font-size: 18px; font-weight: 500; color: #010180; line-height: normal;">Acailandia-MA</span>
          </div>
          <button id="btn-trocar-cidade" style="display: inline-flex; align-items: center; gap: 8px; padding: 12px 24px; background: #010180; color: #00EF52; border-radius: 999px; font-size: 18px; font-weight: 500; border: none; cursor: pointer; white-space: nowrap;">
            <img src="/images/icon-trocar-cidade.svg" alt="" width="18" height="18" style="display: block; flex-shrink: 0;" />
            Trocar Cidade
          </button>
        </div>

      </div>
    </div>

    <!-- Cards de planos -->
    <!-- Wrapper com padding-top para acomodar o badge do card 600 Mega -->
    <div class="planos-cards" style="display: flex; gap: 24px; align-items: center; justify-content: center; width: 100%; padding-top: 28px;">

      <!-- Card 600 Mega (destaque: Melhor Valor) -->
      <div style="flex: 0 0 calc(25% - 18px); position: relative;">
        <!-- Badge Melhor Valor: posicionado acima do card -->
        <div style="position: absolute; top: -14px; left: 50%; transform: translateX(-50%); background: #FFDD00; padding: 6px 36px; border-radius: 999px; z-index: 2; white-space: nowrap;">
          <span style="font-size: 16px; font-weight: 600; color: #010180; line-height: normal;">Melhor Valor</span>
        </div>
        <div style="display: flex; flex-direction: column; gap: 24px; padding: 32px 24px; border-radius: 24px; background: #0939CF; width: 100%;">
          <p style="font-size: 54px; font-weight: 600; color: #00EF52; margin: 0; line-height: normal; white-space: nowrap;">600 Mega</p>
          <div style="height: 1px; background: rgba(255,255,255,0.25); width: 100%;"></div>
          <div style="display: flex; flex-direction: column; gap: 8px;">
            <div style="display: flex; align-items: baseline; gap: 0;">
              <span id="card-preco-600" style="font-size: 46px; font-weight: 600; color: #00EF52; line-height: normal;">R$94,99*</span>
              <span style="font-size: 24px; font-weight: 400; color: #fff; line-height: normal;">/mês</span>
            </div>
            <p id="card-condicao-600" style="font-size: 18px; font-weight: 400; color: #fff; margin: 0; line-height: normal;">Valor fixo por 12 meses.</p>
          </div>
          <div style="display: flex; flex-direction: column; gap: 8px;">
            <div style="display: flex; gap: 8px; align-items: center;">
              <img src="/images/icon-globoplay.png" alt="GloboPlay" width="38" height="38" style="display: block; flex-shrink: 0;" />
              <span style="font-size: 18px; font-weight: 400; color: #fff; line-height: normal;">GloboPlay incluído</span>
            </div>
            <div style="display: flex; gap: 8px; align-items: center;">
              <img src="/images/icon-wifi.svg" alt="" width="32" height="32" style="display: block; flex-shrink: 0;" />
              <span style="font-size: 18px; font-weight: 400; color: #fff; line-height: normal;">Wi-Fi 6</span>
            </div>
            <div style="display: flex; gap: 8px; align-items: center;">
              <img src="/images/icon-check.svg" alt="" width="32" height="32" style="display: block; flex-shrink: 0;" />
              <span style="font-size: 18px; font-weight: 400; color: #fff; line-height: normal;">Internet 100% Fibra Óptica</span>
            </div>
          </div>
          <a id="btn-contratar-600" data-plano="600 Mega" data-chave="p600" href="/contratar?plano=600+Mega&cidade=Acailandia-MA&preco=R%2494%2C99&condicao=Valor+fixo+por+12+meses." style="display: flex; align-items: center; justify-content: center; background: #00EF52; color: #010180; font-size: 18px; font-weight: 600; padding: 12px 36px; border-radius: 999px; text-decoration: none; white-space: nowrap; height: 48px;">
            Contratar Online
          </a>
          <p style="font-size: 14px; font-weight: 400; color: #fff; margin: 0; text-align: center; line-height: normal;">*Valor Exclusivo no Cartão de Crédito.</p>
        </div>
      </div>

      <!-- Card 800 Mega -->
      <div style="flex: 0 0 calc(25% - 18px); display: flex; flex-direction: column; gap: 24px; padding: 32px 24px; border-radius: 24px; background: linear-gradient(216.5deg, #010180 9.8%, #0939CF 99.2%);">
        <p style="font-size: 54px; font-weight: 600; color: #00EF52; margin: 0; line-height: normal; white-space: nowrap;">800 Mega</p>
        <div style="height: 1px; background: rgba(255,255,255,0.25); width: 100%;"></div>
        <div style="display: flex; flex-direction: column; gap: 8px;">
          <div style="display: flex; align-items: baseline; gap: 0;">
            <span id="card-preco-800" style="font-size: 46px; font-weight: 600; color: #00EF52; line-height: normal;">R$99,99*</span>
            <span style="font-size: 24px; font-weight: 400; color: #fff; line-height: normal;">/mês</span>
          </div>
          <p id="card-condicao-800" style="font-size: 18px; font-weight: 400; color: #fff; margin: 0; line-height: normal;">Valor fixo por 12 meses.</p>
        </div>
        <div style="display: flex; flex-direction: column; gap: 8px;">
          <div style="display: flex; gap: 8px; align-items: center;">
            <img src="/images/icon-globoplay.png" alt="GloboPlay" width="38" height="38" style="display: block; flex-shrink: 0;" />
            <span style="font-size: 18px; font-weight: 400; color: #fff; line-height: normal;">GloboPlay incluído</span>
          </div>
          <div style="display: flex; gap: 8px; align-items: center;">
            <img src="/images/icon-wifi.svg" alt="" width="32" height="32" style="display: block; flex-shrink: 0;" />
            <span style="font-size: 18px; font-weight: 400; color: #fff; line-height: normal;">Wi-Fi 6</span>
          </div>
          <div style="display: flex; gap: 8px; align-items: center;">
            <img src="/images/icon-check.svg" alt="" width="32" height="32" style="display: block; flex-shrink: 0;" />
            <span style="font-size: 18px; font-weight: 400; color: #fff; line-height: normal;">Internet 100% Fibra Óptica</span>
          </div>
        </div>
        <a id="btn-contratar-800" data-plano="800 Mega" data-chave="p800" href="/contratar?plano=800+Mega&cidade=Acailandia-MA&preco=R%2499%2C99&condicao=Valor+fixo+por+12+meses." style="display: flex; align-items: center; justify-content: center; background: #00EF52; color: #010180; font-size: 18px; font-weight: 600; padding: 12px 36px; border-radius: 999px; text-decoration: none; white-space: nowrap; height: 48px;">
          Contratar Online
        </a>
        <p style="font-size: 14px; font-weight: 400; color: #fff; margin: 0; text-align: center; line-height: normal;">*Valor Exclusivo no Cartão de Crédito.</p>
      </div>

      <!-- Card GIGA -->
      <div style="flex: 0 0 calc(25% - 18px); display: flex; flex-direction: column; gap: 24px; padding: 32px 24px; border-radius: 24px; background: linear-gradient(216.5deg, #010180 9.8%, #0939CF 99.2%);">
        <p style="font-size: 54px; font-weight: 600; color: #00EF52; margin: 0; line-height: normal; white-space: nowrap;">GIGA</p>
        <div style="height: 1px; background: rgba(255,255,255,0.25); width: 100%;"></div>
        <div style="display: flex; flex-direction: column; gap: 8px;">
          <div style="display: flex; align-items: baseline; gap: 0;">
            <span id="card-preco-1gb" style="font-size: 46px; font-weight: 600; color: #00EF52; line-height: normal;">R$139,99*</span>
            <span style="font-size: 24px; font-weight: 400; color: #fff; line-height: normal;">/mês</span>
          </div>
          <p id="card-condicao-1gb" style="font-size: 18px; font-weight: 400; color: #fff; margin: 0; line-height: normal;">Valor fixo por 12 meses.</p>
        </div>
        <div style="display: flex; flex-direction: column; gap: 8px;">
          <div style="display: flex; gap: 8px; align-items: center;">
            <img src="/images/icon-globoplay.png" alt="GloboPlay" width="38" height="38" style="display: block; flex-shrink: 0;" />
            <span style="font-size: 18px; font-weight: 400; color: #fff; line-height: normal;">GloboPlay incluído</span>
          </div>
          <div style="display: flex; gap: 8px; align-items: center;">
            <img src="/images/icon-wifi.svg" alt="" width="32" height="32" style="display: block; flex-shrink: 0;" />
            <span style="font-size: 18px; font-weight: 400; color: #fff; line-height: normal;">Wi-Fi 6</span>
          </div>
          <div style="display: flex; gap: 8px; align-items: center;">
            <img src="/images/icon-check.svg" alt="" width="32" height="32" style="display: block; flex-shrink: 0;" />
            <span style="font-size: 18px; font-weight: 400; color: #fff; line-height: normal;">Internet 100% Fibra Óptica</span>
          </div>
        </div>
        <a id="btn-contratar-1gb" data-plano="GIGA" data-chave="p1gb" href="/contratar?plano=GIGA&cidade=Acailandia-MA&preco=R%24139%2C99&condicao=Valor+fixo+por+12+meses." style="display: flex; align-items: center; justify-content: center; background: #00EF52; color: #010180; font-size: 18px; font-weight: 600; padding: 12px 36px; border-radius: 999px; text-decoration: none; white-space: nowrap; height: 48px;">
          Contratar Online
        </a>
        <p style="font-size: 14px; font-weight: 400; color: #fff; margin: 0; text-align: center; line-height: normal;">*Valor Exclusivo no Cartão de Crédito.</p>
      </div>

    </div>
  </div>

</section>

<style>
  @media (max-width: 768px) {
    /* Seção: padding 64px vertical, 24px lateral */
    .planos-section {
      padding: 64px 24px !important;
    }

    /* Inner container: sem max-width fixo, gap menor */
    .planos-inner {
      gap: 24px !important;
    }

    /* Header: coluna, centralizado */
    .planos-header {
      flex-direction: column !important;
      align-items: center !important;
      text-align: center !important;
      gap: 16px !important;
    }

    /* Bloco título + subtítulo */
    .planos-header > div {
      gap: 16px !important;
      max-width: 100% !important;
      align-items: center !important;
    }

    /* Título h2: 28px, line-height 32px */
    .planos-header h2 {
      font-size: 28px !important;
      line-height: 32px !important;
    }

    /* Subtítulo p: 16px, line-height 20px */
    .planos-header p {
      font-size: 16px !important;
      line-height: 20px !important;
    }

    /* Seletor: coluna, full width, centralizado */
    .planos-seletor {
      flex-direction: column !important;
      width: 100% !important;
      align-items: center !important;
      justify-content: center !important;
      padding: 16px !important;
      gap: 5.6px !important;
      border-radius: 24px !important;
    }

    /* Bloco cidade + botão: coluna, centralizado */
    .planos-seletor > div:first-child {
      flex-direction: column !important;
      align-items: center !important;
      justify-content: center !important;
      gap: 16px !important;
      padding: 0 !important;
      width: 100% !important;
    }

    /* Bloco CIDADE + nome da cidade: texto centralizado */
    .planos-seletor > div:first-child > div:first-child {
      flex-direction: column !important;
      align-items: center !important;
      text-align: center !important;
    }

    /* Botão Trocar Cidade: centralizado, font-size 16px */
    #btn-trocar-cidade {
      font-size: 16px !important;
      border-radius: 24px !important;
      padding: 12px 24px !important;
    }

    /* Radio buttons: linha, centralizado, gap 16px */
    .planos-seletor > div:last-child {
      flex-direction: row !important;
      align-items: center !important;
      justify-content: center !important;
      padding: 8px 16px !important;
      gap: 16px !important;
    }

    /* Cards: coluna, gap 24px, com padding-top para o badge do 600 Mega */
    .planos-cards {
      flex-direction: column !important;
      gap: 24px !important;
      padding-top: 24px !important;
      align-items: stretch !important;
    }

    /* Todos os cards: largura total */
    .planos-cards > div {
      flex: none !important;
      width: 100% !important;
    }

    /* Botão Contratar Online: full width */
    .planos-cards a[style*="border-radius: 999px"] {
      width: 100% !important;
      box-sizing: border-box !important;
      height: 48px !important;
    }
  }
</style>

<script>
  // Ao clicar em "Contratar Online", monta a URL lendo os valores atuais do DOM
  document.querySelectorAll<HTMLAnchorElement>('[data-plano][data-chave]').forEach(btn => {
    btn.addEventListener('click', function (e) {
      e.preventDefault()

      const chave = btn.dataset.chave!   // p600, p800, p1gb
      const plano = btn.dataset.plano!

      // Mapeia chave para o sufixo do ID do elemento
      const sufixo: Record<string, string> = { p600: '600', p800: '800', p1gb: '1gb' }
      const id = sufixo[chave] || chave.replace('p', '')

      // Lê preço e condição atuais do DOM (já atualizados pelo switcher de cidade)
      const precoEl = document.getElementById('card-preco-' + id)
      const condicaoEl = document.getElementById('card-condicao-' + id)
      const cidadeEl = document.getElementById('cidade-label')

      const preco = precoEl?.textContent?.trim() || ''
      const condicao = condicaoEl?.textContent?.trim() || ''
      const cidade = cidadeEl?.textContent?.trim() || 'Acailandia-MA'

      const params = new URLSearchParams({ plano, cidade, preco, condicao })
      window.location.href = '/contratar?' + params.toString()
    })
  })
</script>
