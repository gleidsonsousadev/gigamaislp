<section id="planos" style="width: 100%; background: linear-gradient(123.24deg, #F3FFF7 5.05%, #C5D1DF 100.3%); padding: 80px 32px;">

  <div style="max-width: 1440px; margin: 0 auto; display: flex; flex-direction: column; gap: 32px;">

    <!-- Header da seção: título + seletor de cidade -->
    <div style="display: flex; align-items: center; justify-content: space-between; width: 100%;">

      <!-- Título -->
      <div style="display: flex; flex-direction: column; gap: 11px; max-width: 617px;">
        <h2 style="font-size: 40px; line-height: 48px; font-weight: 500; margin: 0;">
          <span style="color: #010180;">Escolha sua</span>
          <span style="color: #0939CF;"> Experiência</span>
        </h2>
        <p style="font-size: 18px; line-height: 24px; font-weight: 400; color: #010180; margin: 0;">
          Planos pensados para quem não aceita menos que o topo da performance digital.
        </p>
      </div>

      <!-- Seletor: cidade + radio buttons -->
      <div style="display: flex; gap: 5.6px; align-items: center; justify-content: center; padding: 16px; background: rgba(1,1,128,0.1); border-radius: 24px; flex-shrink: 0;">

        <!-- Cidade + Trocar Cidade -->
        <div style="display: flex; gap: 16px; align-items: center; padding: 6px 6px 6px 17px; border-radius: 32px;">
          <div style="display: flex; flex-direction: column;">
            <span style="font-size: 12px; font-weight: 600; color: #0939CF; letter-spacing: 1.56px; line-height: normal;">CIDADE</span>
            <span id="cidade-label" style="font-size: 18px; font-weight: 500; color: #010180; line-height: normal;">Santo André-SP</span>
          </div>
          <button id="btn-trocar-cidade" style="display: inline-flex; align-items: center; gap: 8px; padding: 12px 24px; background: #010180; color: #00EF52; border-radius: 24px; font-size: 18px; font-weight: 500; border: none; cursor: pointer; white-space: nowrap;">
            <img src="/images/icon-trocar-cidade.svg" alt="" width="18" height="18" style="display: block; flex-shrink: 0;" />
            Trocar Cidade
          </button>
        </div>

        <!-- Radio buttons -->
        <div style="display: flex; gap: 16px; align-items: center; padding: 8px 16px; border-radius: 24px;">
          <label style="display: flex; gap: 8px; align-items: center; cursor: pointer;">
            <input type="radio" name="plano-tipo" value="internet" checked style="width: 18px; height: 18px; accent-color: #0939CF; cursor: pointer;" />
            <span style="font-size: 15px; font-weight: 500; color: #010180; white-space: nowrap;">Internet</span>
          </label>
          <label style="display: flex; gap: 8px; align-items: center; cursor: pointer;">
            <input type="radio" name="plano-tipo" value="streaming" style="width: 18px; height: 18px; accent-color: #0939CF; cursor: pointer;" />
            <span style="font-size: 15px; font-weight: 500; color: #010180; white-space: nowrap;">Internet com Streaming</span>
          </label>
        </div>

      </div>
    </div>

    <!-- Cards de planos -->
    <!-- Wrapper com padding-top para acomodar o badge do card 600 Mega -->
    <div style="display: flex; gap: 24px; align-items: center; width: 100%; padding-top: 28px;">

      <!-- Card 400 Mega -->
      <div style="flex: 0 0 calc(25% - 18px); display: flex; flex-direction: column; gap: 24px; padding: 32px 24px; border-radius: 24px; background: linear-gradient(214.15deg, #010180 9.8%, #0939CF 99.2%);">

        <p style="font-size: 54px; font-weight: 600; color: #00EF52; margin: 0; line-height: normal; white-space: nowrap;">400 Mega</p>
        <div style="height: 1px; background: rgba(255,255,255,0.25); width: 100%;"></div>
        <div style="display: flex; flex-direction: column; gap: 8px;">
          <div style="display: flex; align-items: baseline; gap: 0;">
            <span style="font-size: 46px; font-weight: 600; color: #00EF52; line-height: normal;">R$102,89</span>
            <span style="font-size: 24px; font-weight: 400; color: #fff; line-height: normal;">/mês</span>
          </div>
          <p style="font-size: 18px; font-weight: 400; color: #fff; margin: 0; line-height: normal;">Após 3 meses aumenta R$20,00</p>
        </div>
        <div style="display: flex; flex-direction: column; gap: 8px;">
          <div style="display: flex; gap: 8px; align-items: center;">
            <img src="/images/icon-hbomax.png" alt="HBO Max" width="38" height="38" style="display: block; flex-shrink: 0;" />
            <span style="font-size: 18px; font-weight: 400; color: #fff; line-height: normal;">Incluso HBO Max</span>
          </div>
          <div style="display: flex; gap: 8px; align-items: center;">
            <img src="/images/icon-check.svg" alt="" width="32" height="32" style="display: block; flex-shrink: 0;" />
            <span style="font-size: 18px; font-weight: 400; color: #fff; line-height: normal;">Internet 100% Fibra Óptica</span>
          </div>
        </div>
        <a href="#contratar" style="display: flex; align-items: center; justify-content: center; background: #00EF52; color: #010180; font-size: 18px; font-weight: 600; padding: 12px 36px; border-radius: 999px; text-decoration: none; white-space: nowrap; height: 48px;">
          Contratar Online
        </a>
