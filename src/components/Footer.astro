<footer style="width: 100%; background: #000026; border-top: 2px solid #000050;">

  <div style="max-width: 1440px; margin: 0 auto; padding: 48px 32px; display: flex; flex-direction: column; gap: 25px;">

    <!-- Bloco superior: logo + slogan + botões -->
    <div style="display: flex; flex-direction: column; gap: 8px; width: 100%;">

      <!-- Linha: logo + botões -->
      <div style="display: flex; align-items: center; justify-content: space-between; width: 100%;">

        <!-- Logo -->
        <a href="/" aria-label="Giga+" style="display: block; width: 150px; flex-shrink: 0;">
          <img src="/images/logo.svg" alt="Giga+" style="width: 100%; height: auto; display: block;" />
        </a>

        <!-- Botões de contato -->
        <div style="display: flex; gap: 16px; align-items: center; flex-shrink: 0;">

          <!-- Botão telefone (outline verde) -->
          <a href="tel:08007302200" style="
            display: inline-flex;
            gap: 8px;
            align-items: center;
            justify-content: center;
            padding: 12px 24px;
            border-radius: 999px;
            border: 1px solid #00EF52;
            background: transparent;
            color: #00EF52;
            font-size: 18px;
            font-weight: 600;
            text-decoration: none;
            white-space: nowrap;
          ">
            <img src="http://localhost:3845/assets/28e33bb1cdd568215bdad37a3953972f70de2387.svg" alt="" width="24" height="24" style="display: block; flex-shrink: 0;" />
            0800 730 2200
          </a>

          <!-- Botão WhatsApp (verde filled) -->
          <a href="https://wa.me/5511936192300" target="_blank" rel="noopener" style="
            display: inline-flex;
            gap: 8px;
            align-items: center;
            justify-content: center;
            padding: 12px 24px;
            border-radius: 999px;
            background: #00EF52;
            color: #091540;
            font-size: 18px;
            font-weight: 600;
            text-decoration: none;
            white-space: nowrap;
          ">
            <img src="/images/icon-whatsapp-dark.svg" alt="" width="24" height="24" style="display: block; flex-shrink: 0;" />
            Contratar pelo WhatsApp
          </a>

        </div>
      </div>

      <!-- Slogan -->
      <p style="font-size: 16px; font-weight: 400; color: #fff; line-height: 24px; margin: 0;">
        Uma boa história merece alta velocidade.
      </p>

      <!-- Parceiro autorizado -->
      <p style="font-size: 16px; font-weight: 600; color: #00EF52; line-height: 24px; margin: 0; letter-spacing: 0.04em;">
        PARCEIRO AUTORIZADO
      </p>

    </div>

    <!-- Linha divisória -->
    <div style="width: 100%; height: 1px; background: rgba(255,255,255,0.15);"></div>

    <!-- Barra inferior: links + copyright -->
    <div style="display: flex; align-items: center; justify-content: space-between; width: 100%;">

      <!-- Links legais -->
      <div style="display: flex; gap: 24px; align-items: center;">
        <a href="#" style="font-size: 16px; font-weight: 400; color: #fff; text-decoration: none; line-height: 24px; white-space: nowrap;">Política de Privacidade</a>
        <a href="#" style="font-size: 16px; font-weight: 400; color: #fff; text-decoration: none; line-height: 24px; white-space: nowrap;">Termos de Uso</a>
      </div>

      <!-- Copyright -->
      <p style="font-size: 16px; font-weight: 400; color: #fff; line-height: 24px; margin: 0; text-align: right; white-space: nowrap;">
        © 2026 Giga+ Fibra. MF PROMOCOES E VENDAS LTDA - CNPJ  61.625.911/0001-07
      </p>

    </div>

  </div>

</footer>
