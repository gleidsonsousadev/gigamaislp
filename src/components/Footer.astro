<footer class="site-footer" style="width: 100%; background: #000026; border-top: 2px solid #000050;">

  <div class="footer-inner" style="max-width: 1440px; margin: 0 auto; padding: 48px 32px; display: flex; flex-direction: column; gap: 25px;">

    <!-- Linha principal desktop: logo+slogan+parceiro à esquerda, botões à direita -->
    <div class="footer-main" style="display: flex; align-items: center; justify-content: space-between; width: 100%;">

      <!-- Esquerda: logo + slogan + parceiro -->
      <div class="footer-brand" style="display: flex; flex-direction: column; gap: 8px;">

        <a href="/" aria-label="Giga+" class="footer-logo" style="display: block; width: 150px; flex-shrink: 0;">
          <img src="/images/logo.svg" alt="Giga+" style="width: 100%; height: auto; display: block;" />
        </a>

        <p class="footer-slogan" style="font-size: 16px; font-weight: 400; color: #fff; line-height: 24px; margin: 0;">
          Uma boa história merece alta velocidade.
        </p>

        <p class="footer-parceiro" style="font-size: 16px; font-weight: 600; color: #00EF52; line-height: 24px; margin: 0; letter-spacing: 0.04em;">
          PARCEIRO AUTORIZADO
        </p>


      </div>

      <!-- Direita: botões de contato -->
      <div class="footer-btns" style="display: flex; gap: 16px; align-items: center; flex-shrink: 0;">

        <!-- Botão telefone (outline verde) -->
        <a href="tel:08007302200" class="footer-btn-tel" style="
          display: inline-flex;
          gap: 8px;
          align-items: center;
          justify-content: center;
          padding: 12px 24px;
          border-radius: 999px;
          border: 1px solid #00EF52;
          background: transparent;
          color: #00EF52;
          font-size: 18px;
          font-weight: 600;
          text-decoration: none;
          white-space: nowrap;
        ">
          <img src="/images/icon-telefone.svg" alt="" width="24" height="24" style="display: block; flex-shrink: 0;" />
          0800 730 2200
        </a>

        <!-- Botão WhatsApp (verde filled) -->
        <a href="https://wa.me/5511936192300" target="_blank" rel="noopener" class="footer-btn-wa" style="
          display: inline-flex;
          gap: 8px;
          align-items: center;
          justify-content: center;
          padding: 12px 24px;
          border-radius: 999px;
          background: #00EF52;
          color: #091540;
          font-size: 18px;
          font-weight: 600;
          text-decoration: none;
          white-space: nowrap;
        ">
          <img src="/images/icon-whatsapp-dark.svg" alt="" width="24" height="24" style="display: block; flex-shrink: 0;" />
          Contratar pelo WhatsApp
        </a>

      </div>

    </div>

    <!-- Linha divisória -->
    <div class="footer-divider" style="width: 100%; height: 1px; background: rgba(255,255,255,0.15);"></div>

    <!-- Barra inferior: links + copyright -->
    <div class="footer-bottom" style="display: flex; align-items: center; justify-content: space-between; width: 100%;">

      <!-- Links legais -->
      <div class="footer-links" style="display: flex; gap: 24px; align-items: center;">
        <a href="#" style="font-size: 16px; font-weight: 400; color: #fff; text-decoration: none; line-height: 24px; white-space: nowrap;">Política de Privacidade</a>
        <a href="#" style="font-size: 16px; font-weight: 400; color: #fff; text-decoration: none; line-height: 24px; white-space: nowrap;">Termos de Uso</a>
      </div>

      <!-- Parceiro comercial + empresa (direita) -->
      <div class="footer-empresa-block" style="display: flex; flex-direction: column; gap: 2px; align-items: flex-end; text-align: right;">
        <p class="footer-parceiro-comercial" style="font-size: 16px; font-weight: 600; color: #00EF52; line-height: 24px; margin: 0; letter-spacing: 0.04em;">PARCEIRO COMERCIAL AUTORIZADO</p>
        <p style="font-size: 16px; font-weight: 400; color: #fff; line-height: 24px; margin: 0;">MF Promocoes e Vendas Ltda</p>
        <p style="font-size: 16px; font-weight: 400; color: #fff; line-height: 24px; margin: 0;">CNPJ: 61.625.911/0001-07</p>
      </div>

    </div>

  </div>

</footer>

<style>
  @media (max-width: 768px) {
    /* Container: coluna, centralizado, padding top 71px, gap 27px */
    /* padding-bottom 116px = altura da sticky bar, para o conteúdo não ficar atrás dela */
    .footer-inner {
      padding: 71px 24px 132px !important;
      align-items: center !important;
      gap: 27px !important;
    }

    /* Linha principal: coluna, centralizado, gap 27px */
    .footer-main {
      flex-direction: column !important;
      align-items: center !important;
      justify-content: center !important;
      gap: 27px !important;
      width: 100% !important;
    }

    /* Brand: coluna, centralizado, gap 10px, width 277px */
    .footer-brand {
      align-items: center !important;
      gap: 10px !important;
      width: 277px !important;
    }

    /* Slogan, parceiro e empresa: centralizados */
    .footer-slogan,
    .footer-parceiro,
    .footer-empresa {
      text-align: center !important;
      align-items: center !important;
    }

    /* Botões: coluna, width 342px, gap 14px */
    .footer-btns {
      flex-direction: column !important;
      width: 342px !important;
      gap: 14px !important;
      align-items: stretch !important;
    }

    /* Botão telefone: outline verde, full width */
    .footer-btn-tel {
      width: 100% !important;
      justify-content: center !important;
      font-size: 18px !important;
      border-radius: 999px !important;
      border: 1px solid #00EF52 !important;
      color: #00EF52 !important;
      background: transparent !important;
      box-sizing: border-box !important;
    }

    /* Botão WhatsApp: filled verde, full width */
    .footer-btn-wa {
      width: 100% !important;
      justify-content: center !important;
      font-size: 16px !important;
      border-radius: 999px !important;
      background: #00EF52 !important;
      color: #091540 !important;
      box-sizing: border-box !important;
    }

    /* Linha divisória: oculta no mobile */
    .footer-divider {
      display: none !important;
    }

    /* Barra inferior: coluna, centralizado, gap 24px, width 342px */
    .footer-bottom {
      flex-direction: column !important;
      align-items: center !important;
      justify-content: center !important;
      gap: 24px !important;
      width: 342px !important;
    }

    /* Links: em linha, space-between, full width */
    .footer-links {
      flex-direction: row !important;
      justify-content: space-between !important;
      width: 100% !important;
      gap: 0 !important;
    }

    /* Parceiro comercial block: centralizado no mobile */
    .footer-empresa-block {
      align-items: center !important;
      text-align: center !important;
    }
  }
</style>
