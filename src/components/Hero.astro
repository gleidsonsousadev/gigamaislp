<section id="inicio" style="position: relative; width: 100%; height: 588px; background: #000050; overflow: hidden;">

  <!-- Container de 1440px centralizado -->
  <div style="position: relative; max-width: 1440px; margin: 0 auto; height: 100%;">

    <!-- Degradê azul: canto superior esquerdo atrás do H1 -->
    <!-- Figma: elipse 502x502, x=-44,y=-229 → centro em x=207,y=22 no frame 1920 → no container 1440: centro x=-33,y=22 → left=-284,top=-229 -->
    <div style="
      position: absolute;
      z-index: 4;
      left: -200px;
      top: -280px;
      width: 700px;
      height: 700px;
      border-radius: 50%;
      background: #0939CF;
      filter: blur(200px);
      opacity: 0.55;
      pointer-events: none;
    "></div>

    <!-- Degradê verde: parte inferior, sobre a mão da mulher -->
    <!-- Figma: x=729,y=526 no frame 1920 → container 1440: left=489,top=526 -->
    <div style="
      position: absolute;
      z-index: 5;
      left: 489px;
      top: 340px;
      width: 502px;
      height: 502px;
      border-radius: 50%;
      background: #00EF52;
      filter: blur(160px);
      opacity: 0.5;
      pointer-events: none;
    "></div>

    <!-- Imagem da mulher: z-index 2, sobre o degradê azul -->
    <img
      src="/images/bg-woman-hero.png"
      alt=""
      fetchpriority="high"
      style="position: absolute; right: 0; top: 0; width: 1071px; height: 588px; display: block; object-fit: cover; z-index: 2;"
    />

    <!-- Fade da esquerda sobre a imagem para fundir com o fundo -->
    <div style="position: absolute; right: 0; top: 0; width: 1071px; height: 588px; background: linear-gradient(to right, #000050 0%, rgba(0,0,80,0.6) 25%, transparent 55%); pointer-events: none; z-index: 3;"></div>

    <!-- Texto e CTAs: z-index 10 -->
    <div style="position: absolute; left: 0; top: 60%; transform: translateY(-60%); width: 598px; display: flex; flex-direction: column; gap: 24px; z-index: 10;">

      <h1 style="font-size: 56px; line-height: 64px; font-weight: 500; color: #fff; margin: 0;">
        Sua Internet<br>
        <span style="color: #00EF52;">100% Fibra</span> com Estabilidade Premiada
      </h1>

      <p style="font-size: 18px; line-height: 24px; font-weight: 400; color: #fff; margin: 0; width: 526px;">
        Navegue com ultravelocidade e a menor latência do mercado. Perfeito para gamers, streamers e home office de alta performance.
      </p>

      <div style="display: flex; align-items: center; gap: 16px;">
        <a href="#planos" style="display: inline-flex; align-items: center; justify-content: center; border-radius: 999px; border: 1.5px solid #00EF52; color: #00EF52; font-size: 18px; font-weight: 600; padding: 14px 24px; background: transparent; text-decoration: none; white-space: nowrap;">
          Ver Planos
        </a>
        <a href="https://wa.me/5511999999999" target="_blank" rel="noopener noreferrer" style="display: inline-flex; align-items: center; gap: 8px; border-radius: 999px; background: #00EF52; color: #091540; font-size: 18px; font-weight: 600; padding: 12px 24px; text-decoration: none; white-space: nowrap;">
          <img src="/images/icon-whatsapp.svg" alt="" width="24" height="24" style="display:block; flex-shrink:0;" />
          Contratar pelo WhatsApp
        </a>
      </div>

    </div>

    <!-- Badges com glassmorphism -->
    <!-- Melhor Provedor: Figma x=1009, y=184 → no container 1440: x=1009-((1920-1440)/2)=769, y=184 -->
    <div class="badge-glass badge-float-1" style="position: absolute; z-index: 20; left: 740px; top: 130px;">
      <img src="/images/icon-melhor-provedor.svg" alt="" width="22" height="22" style="display:block;" />
      <div style="text-align: center; font-size: 12.6px; line-height: 1.4; font-weight: 500; white-space: nowrap;">
        <p style="color: #fff; margin: 0;">Melhor</p>
        <p style="color: #00EF52; margin: 0;">Provedor</p>
      </div>
    </div>

    <!-- Melhor Velocidade -->
    <div class="badge-glass badge-float-2" style="position: absolute; z-index: 20; left: 710px; top: 355px;">
      <img src="/images/icon-melhor-velocidade.svg" alt="" width="22" height="22" style="display:block;" />
      <div style="text-align: center; font-size: 12.6px; line-height: 1.4; font-weight: 500; white-space: nowrap;">
        <p style="color: #fff; margin: 0;">Melhor</p>
        <p style="color: #00EF52; margin: 0;">Velocidade</p>
      </div>
    </div>

    <!-- 4.9 No Google -->
    <div class="badge-glass badge-float-3" style="position: absolute; z-index: 20; left: 1175px; top: 250px;">
      <img src="/images/icon-avaliacao-google.svg" alt="" width="22" height="22" style="display:block;" />
      <div style="text-align: center; font-size: 12.6px; line-height: 1.4; font-weight: 500; white-space: nowrap;">
        <p style="color: #fff; margin: 0;">4.9</p>
        <p style="color: #00EF52; margin: 0;">No Google</p>
      </div>
    </div>

    <!-- Melhor Estabilidade: Figma x=1312, y=466 → container: x=1072, y=466 -->
    <div class="badge-glass badge-float-4" style="position: absolute; z-index: 20; left: 1042px; top: 412px;">
      <img src="/images/icon-melhor-estabilidade.svg" alt="" width="22" height="22" style="display:block;" />
      <div style="text-align: center; font-size: 12.6px; line-height: 1.4; font-weight: 500; white-space: nowrap;">
        <p style="color: #fff; margin: 0;">Melhor</p>
        <p style="color: #00EF52; margin: 0;">Estabilidade</p>
      </div>
    </div>

  </div>

</section>

<style>
  .badge-glass {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 5.6px;
    padding: 8.4px;
    border-radius: 7.7px;
    border: 0.7px solid rgba(255, 255, 255, 0.11);
    background: linear-gradient(to bottom, rgba(255,255,255,0.16), rgba(255,255,255,0.02));
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    animation: float 4s ease-in-out infinite;
  }

  /* Cada badge com animação própria — direção, amplitude e duração distintas */
  .badge-float-1 { animation: float1 4.2s ease-in-out infinite; }
  .badge-float-2 { animation: float2 5.8s ease-in-out infinite; }
  .badge-float-3 { animation: float3 3.7s ease-in-out infinite; }
  .badge-float-4 { animation: float4 6.3s ease-in-out infinite; }

  /* Badge 1: sobe levemente */
  @keyframes float1 {
    0%   { transform: translateY(0px); }
    55%  { transform: translateY(-7px); }
    100% { transform: translateY(0px); }
  }
  /* Badge 2: desce e sobe mais lentamente */
  @keyframes float2 {
    0%   { transform: translateY(0px); }
    40%  { transform: translateY(5px); }
    100% { transform: translateY(0px); }
  }
  /* Badge 3: movimento diagonal sutil */
  @keyframes float3 {
    0%   { transform: translate(0px, 0px); }
    50%  { transform: translate(3px, -6px); }
    100% { transform: translate(0px, 0px); }
  }
  /* Badge 4: amplitude menor, mais lento */
  @keyframes float4 {
    0%   { transform: translateY(0px); }
    60%  { transform: translateY(-4px); }
    100% { transform: translateY(0px); }
  }
</style>
