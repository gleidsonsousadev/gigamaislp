<section class="porque-section" style="position: relative; width: 100%; background: #000026; border-bottom: 2px solid #000050; overflow: hidden; height: 824px;">

  <!-- Container 1440px centralizado — base de posicionamento -->
  <div style="position: absolute; inset: 0; display: flex; justify-content: center;">
    <div style="position: relative; width: 100%; max-width: 1440px;">

      <!-- Imagem da mão: sem máscara, com fade nas bordas -->
      <img
        src="/images/bg-mao-porque-ser-giga.png"
        alt=""
        class="porque-img"
        style="
          position: absolute;
          left: -85px;
          top: 77px;
          width: 1200px;
          height: 670px;
          display: block;
          object-fit: cover;
        "
      />
      <!-- Fade top -->
      <div style="
        position: absolute;
        left: -85px;
        top: 77px;
        width: 1200px;
        height: 140px;
        background: linear-gradient(to bottom, #000026, transparent);
        pointer-events: none;
        z-index: 2;
      "></div>
      <!-- Fade bottom -->
      <div style="
        position: absolute;
        left: -85px;
        top: calc(77px + 670px - 140px);
        width: 1200px;
        height: 140px;
        background: linear-gradient(to top, #000026, transparent);
        pointer-events: none;
        z-index: 2;
      "></div>
      <!-- Fade right -->
      <div style="
        position: absolute;
        left: calc(-85px + 850px);
        top: 77px;
        width: 350px;
        height: 670px;
        background: linear-gradient(to right, transparent, #000026);
        pointer-events: none;
        z-index: 2;
      "></div>


      <!-- Degradê azul mobile: topo esquerdo (x=-269, y=-137, 502x502px) -->
      <div class="porque-degrade-azul-mobile" style="display: none; position: absolute; left: -269px; top: -137px; width: 502px; height: 502px; border-radius: 50%; background: #0939CF; filter: blur(120px); opacity: 0.55; pointer-events: none; z-index: 2;"></div>

      <!-- Título mobile: visível apenas no mobile (top=71, left=24) -->
      <h2 class="porque-titulo-mobile" style="display: none; margin: 0; font-weight: 500; color: #00EF52; z-index: 10;">
        Por que ser <span style="color: #fff;">Giga+</span> é sua melhor escolha?
      </h2>

      <!-- Imagem da mão mobile: visível apenas no mobile -->
      <img
        src="/images/bg-mao-porque-ser-giga-mobile.png"
        alt=""
        class="porque-img-mobile"
        style="display: none; z-index: 1;"
      />

      <!-- Fade suave sobre a imagem mobile (topo) -->
      <div class="porque-fade-mobile" style="display: none; position: absolute; left: 0; top: 520px; width: 100%; height: 200px; background: linear-gradient(to bottom, #000026 0%, #000026 20%, rgba(0,0,38,0.7) 60%, transparent 100%); pointer-events: none; z-index: 3;"></div>

      <!-- Conteúdo direito: x=1114-240=874, y=111, w=469, h=603 -->
      <div class="porque-content" style="
        position: absolute;
        left: 874px;
        top: 111px;
        width: 469px;
        height: 603px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        z-index: 10;
      ">

        <!-- Título -->
        <h2 style="font-size: 40px; font-weight: 500; line-height: 48px; margin: 0; color: #00EF52; width: 469px;">
          Por que ser <span style="color: #fff;">Giga+</span> é sua melhor escolha?
        </h2>

        <!-- 3 cards glassmorphism: width=353 -->
        <div class="porque-cards" style="display: flex; flex-direction: column; gap: 24px; width: 353px;">

          <!-- Card Wi-Fi 6 -->
          <div class="card-porque">
            <img src="/images/icon-wifi.svg" alt="" width="32" height="32" style="display: block; flex-shrink: 0;" />
            <div style="display: flex; flex-direction: column; gap: 6px;">
              <p style="font-size: 24px; font-weight: 600; color: #fff; margin: 0; line-height: 28px;">Tecnologia Wi-fi 6</p>
              <p style="font-size: 16px; font-weight: 400; color: #fff; margin: 0; line-height: 22.75px;">Até 4x mais velocidade sem fios e redução de 40% na latência (Ping baixo para Gamers).</p>
            </div>
          </div>

          <!-- Card Rede 100% Fibra -->
          <div class="card-porque">
            <img src="/images/icon-rede-fibra.svg" alt="" width="32" height="32" style="display: block; flex-shrink: 0;" />
            <div style="display: flex; flex-direction: column; gap: 6px;">
              <p style="font-size: 24px; font-weight: 600; color: #fff; margin: 0; line-height: 28px;">Rede Fibra</p>
              <p style="font-size: 16px; font-weight: 400; color: #fff; margin: 0; line-height: 22.75px;">Conexão estável do poste até dentro da sua sala.</p>
            </div>
          </div>

          <!-- Card Franquia Ilimitada -->
          <div class="card-porque">
            <img src="/images/icon-franquia-iliminada.svg" alt="" width="32" height="32" style="display: block; flex-shrink: 0;" />
            <div style="display: flex; flex-direction: column; gap: 6px;">
              <p style="font-size: 24px; font-weight: 600; color: #fff; margin: 0; line-height: 28px;">Franquia Ilimitada</p>
              <p style="font-size: 16px; font-weight: 400; color: #fff; margin: 0; line-height: 22.75px;">Navegue, assista e baixe sem preocupações com limites de dados.</p>
            </div>
          </div>

        </div>
      </div>

    </div>
  </div>

</section>

<style>
  .card-porque {
    display: flex;
    flex-direction: column;
    gap: 5.6px;
    padding: 16px;
    border-radius: 1.5rem;
    border: 0.7px solid rgba(255, 255, 255, 0.11);
    background: linear-gradient(to bottom, rgba(255,255,255,0.16), rgba(255,255,255,0.02));
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    width: 100%;
    box-sizing: border-box;
  }

  @media (max-width: 768px) {
    /* Seção: altura fixa 986px, imagem da mão mobile no fundo */
    .porque-section {
      height: 986px !important;
    }

    /* Container principal: ocupa toda a seção */
    .porque-section > div {
      position: absolute !important;
      inset: 0 !important;
    }

    /* Container interno: também full */
    .porque-section > div > div {
      width: 100% !important;
      max-width: 100% !important;
    }

    /* Imagem desktop: oculta */
    .porque-img {
      display: none !important;
    }

    /* Fades desktop: ocultos */
    .porque-section > div > div > div[style*="gradient"] {
      display: none !important;
    }

    /* Degradê azul mobile: visível */
    .porque-degrade-azul-mobile {
      display: block !important;
    }

    /* Fade suave sobre a imagem mobile: visível */
    .porque-fade-mobile {
      display: block !important;
    }

    /* Imagem da mão mobile: centralizada na tela, parte inferior */
    .porque-img-mobile {
      display: block !important;
      position: absolute !important;
      left: 50% !important;
      transform: translateX(-50%) !important;
      top: 590px !important;
      width: 100% !important;
      height: 396px !important;
      object-fit: cover !important;
      object-position: center top !important;
    }

    /* Conteúdo: centralizado na tela (left=43 com width=304 = centrado em 390px) */
    .porque-content {
      position: absolute !important;
      left: 50% !important;
      transform: translateX(-50%) !important;
      top: 155px !important;
      width: 304px !important;
      height: auto !important;
      gap: 24px !important;
      justify-content: flex-start !important;
      padding: 0 !important;
      z-index: 10 !important;
    }

    /* Título: centralizado, 28px/32px */
    .porque-titulo-mobile {
      display: block !important;
      position: absolute !important;
      left: 50% !important;
      transform: translateX(-50%) !important;
      top: 71px !important;
      width: 342px !important;
      font-size: 28px !important;
      line-height: 32px !important;
      text-align: center !important;
    }

    /* Título desktop dentro do content: oculto */
    .porque-content > h2 {
      display: none !important;
    }

    /* Cards: coluna, gap 24px, full width */
    .porque-cards {
      width: 100% !important;
      gap: 24px !important;
    }

    /* Cada card: coluna, centralizado (ícone + título + texto centralizados) */
    .card-porque {
      flex-direction: column !important;
      align-items: center !important;
      gap: 5.6px !important;
      text-align: center !important;
    }

    /* Título do card: 20px */
    .card-porque p[style*="24px"] {
      font-size: 20px !important;
      line-height: 28px !important;
    }
  }
</style>
